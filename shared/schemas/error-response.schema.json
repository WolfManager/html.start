{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "magneto/shared/error-response.schema.json",
  "title": "ErrorResponse",
  "type": "object",
  "required": ["error"],
  "properties": {
    "error": {
      "type": "string",
      "minLength": 1
    },
    "ok": {
      "type": "boolean"
    },
    "code": {
      "type": "string"
    },
    "details": {
      "type": ["object", "array", "string", "null"]
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "requestId": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
