PORT=3000
MAGNETO_NODE_PORT=3000
MAGNETO_DJANGO_PORT=8000
JWT_SECRET=change-this-secret
ADMIN_USER=admin
ADMIN_PASSWORD=change-this-password

# URL for the Django backend (used by routing control + health verify)
DJANGO_API_URL=http://127.0.0.1:8000

# Security tuning
LOGIN_WINDOW_MINUTES=15
LOGIN_RATE_LIMIT_COUNT=20
LOCKOUT_THRESHOLD=5
LOCKOUT_MINUTES=15
ADMIN_WINDOW_SECONDS=60
ADMIN_RATE_LIMIT_COUNT=120

# Backup tuning
BACKUP_MIN_INTERVAL_MINUTES=15
BACKUP_SCHEDULE_MINUTES=60
MAX_BACKUP_FILES=120

# Trend chart tuning
TREND_DAILY_POINTS=14
TREND_WEEKLY_POINTS=8

# MAGNETO Assistant (AI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_MODEL_CANDIDATES=gpt-5-mini,gpt-5,gpt-4.1-mini,gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MODEL_CANDIDATES=claude-sonnet-4-6,claude-opus-4-6,claude-haiku-4-5-20251001
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_CANDIDATES=gemini-2.5-flash,gemini-2.5-pro,gemini-flash-latest
AI_PRIMARY_PROVIDER=openai
AI_FALLBACK_PROVIDER=anthropic
AI_PROVIDER_ORDER=openai,anthropic,gemini
AI_ROUTING_MODE=smart
ASSISTANT_COMPLEX_QUERY_WORDS=35
ASSISTANT_COMPLEX_QUERY_CHARS=220
ASSISTANT_WINDOW_SECONDS=60
ASSISTANT_RATE_LIMIT_COUNT=30
ASSISTANT_MAX_CHARS=500
ASSISTANT_MODEL_DISCOVERY_TTL_SECONDS=21600
ASSISTANT_CACHE_TTL_SECONDS=900
ASSISTANT_CACHE_MAX_ENTRIES=500
ASSISTANT_MEMORY_MAX_ITEMS=2000
ASSISTANT_SIMPLE_QUERY_WORDS=5
