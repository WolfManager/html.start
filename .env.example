PORT=3000
MAGNETO_NODE_PORT=3000
MAGNETO_DJANGO_PORT=8000
MAGNETO_WEB_BASE=http://localhost:3000
MAGNETO_API_BASE=
MAGNETO_HEALTH_API_TARGET=node
MAGNETO_BASE_URL=http://localhost:3000
MAGNETO_NODE_BASE_URL=http://127.0.0.1:3000
MAGNETO_DJANGO_BASE_URL=http://127.0.0.1:8000
MAGNETO_PYTHON=python
JWT_SECRET=change-this-secret
ADMIN_USER=admin
ADMIN_PASSWORD=change-this-password
MAGNETO_ADMIN_USER=
MAGNETO_ADMIN_PASSWORD=

# URL for the Django backend (used by routing control + health verify)
DJANGO_API_URL=http://127.0.0.1:8000

# Security tuning
LOG_LEVEL=info
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3100,http://127.0.0.1:3100
LOGIN_WINDOW_MINUTES=15
LOGIN_RATE_LIMIT_COUNT=20
LOCKOUT_THRESHOLD=5
LOCKOUT_MINUTES=15
ADMIN_WINDOW_SECONDS=60
ADMIN_RATE_LIMIT_COUNT=120
SEARCH_CACHE_TTL_SECONDS=300
SEARCH_CACHE_MAX_ENTRIES=500
SEARCH_PROXY_TIMEOUT_MS=5000

# Backup tuning
BACKUP_MIN_INTERVAL_MINUTES=15
BACKUP_SCHEDULE_MINUTES=60
MAX_BACKUP_FILES=120

# Trend chart tuning
TREND_DAILY_POINTS=14
TREND_WEEKLY_POINTS=8

# MAGNETO Assistant (AI)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_MODEL_CANDIDATES=gpt-5-mini,gpt-5,gpt-4.1-mini,gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MODEL_CANDIDATES=claude-sonnet-4-6,claude-opus-4-6,claude-haiku-4-5-20251001
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_CANDIDATES=gemini-2.5-flash,gemini-2.5-pro,gemini-flash-latest
OLLAMA_ENABLED=0
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_MODEL_CANDIDATES=llama3.1:8b,mistral:7b,phi3:mini
AI_PRIMARY_PROVIDER=openai
AI_FALLBACK_PROVIDER=anthropic
AI_PROVIDER_ORDER=openai,anthropic,gemini,ollama
AI_ROUTING_MODE=smart
ASSISTANT_COMPLEX_QUERY_WORDS=35
ASSISTANT_COMPLEX_QUERY_CHARS=220
ASSISTANT_WINDOW_SECONDS=60
ASSISTANT_RATE_LIMIT_COUNT=30
ASSISTANT_MAX_CHARS=500
ASSISTANT_HISTORY_MESSAGES=14
ASSISTANT_HISTORY_CHARS=1200
ASSISTANT_REPLY_MAX_CHARS=1200
ASSISTANT_MODEL_TEMPERATURE=0.4
ASSISTANT_OPENAI_MAX_TOKENS=600
ASSISTANT_ANTHROPIC_MAX_TOKENS=600
ASSISTANT_GEMINI_MAX_TOKENS=600
ASSISTANT_OLLAMA_MAX_TOKENS=600
ASSISTANT_MODEL_DISCOVERY_TTL_SECONDS=21600
ASSISTANT_CACHE_TTL_SECONDS=900
ASSISTANT_CACHE_MAX_ENTRIES=500
ASSISTANT_MEMORY_MAX_ITEMS=2000
ASSISTANT_SIMPLE_QUERY_WORDS=5

# MAGNETO Assistant Voice (Coqui TTS)
ASSISTANT_TTS_ENABLED=1
ASSISTANT_TTS_MAX_CHARS=1200
ASSISTANT_TTS_TIMEOUT_MS=20000
COQUI_TTS_API_URL=http://localhost:5002/api/tts
COQUI_TTS_API_KEY=
COQUI_TTS_API_KEY_HEADER=X-API-Key
COQUI_TTS_DEFAULT_SPEAKER=Daisy Studious
COQUI_TTS_DEFAULT_LANGUAGE=en
COQUI_TTS_DEFAULT_MODEL=

# Search parity + validation scripts
PARITY_MODE=strict
PARITY_WRITE_REPORT=true
PARITY_REPORT_PATH=data/backups/parity/latest-parity-report.json
PARITY_COMPAT_ALERT_MIN_SCORE=8
PARITY_COMPAT_ALERT_MAX_ITEMS=3
MAGNETO_VERIFY_MAX_LATENCY_MS=

# Django index sync tuning
DJANGO_INDEX_SYNC_ENABLED=true
DJANGO_INDEX_SYNC_STARTUP=true
DJANGO_INDEX_SYNC_INTERVAL_MINUTES=15
DJANGO_INDEX_SYNC_MAX_PAGES=50
DJANGO_INDEX_SYNC_PAGE_SIZE=200

# Search click signal tuning
CLICK_SIGNAL_WINDOW_DAYS=30
CLICK_SIGNAL_MAX_BOOST=10
CLICK_SIGNAL_CTR_MAX_BOOST=3
CLICK_SIGNAL_GUARDRAIL_MIN_BASE_SCORE=0.8
CLICK_SIGNAL_GUARDRAIL_MAX_SHARE=0.8
CLICK_SIGNAL_DECAY_HALFLIFE_DAYS=7
CLICK_SIGNAL_DECAY_MIN_WEIGHT=0.05
CLICK_SIGNAL_DEDUP_SECONDS=20

# Optional Django admin token for backend-to-backend admin calls
DJANGO_ADMIN_TOKEN=

# Daily ops task scheduler
OPS_DAILY_TASK_TIME=08:00

# Ops alert webhook (optional)
OPS_ALERT_WEBHOOK_URL=
OPS_ALERT_WEBHOOK_ENABLED=true
OPS_ALERT_ON_SUCCESS=false
OPS_ALERT_RETRY_COUNT=2
OPS_ALERT_TIMEOUT_SECONDS=10
