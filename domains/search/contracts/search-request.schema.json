{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "magneto/domains/search/contracts/search-request.schema.json",
  "title": "SearchRequest",
  "type": "object",
  "required": ["q"],
  "properties": {
    "q": {
      "type": "string",
      "minLength": 1,
      "maxLength": 160
    },
    "language": {
      "type": "string",
      "maxLength": 16
    },
    "category": {
      "type": "string",
      "maxLength": 64
    },
    "source": {
      "type": "string",
      "maxLength": 80
    },
    "sort": {
      "type": "string",
      "enum": ["relevance", "newest", "quality"]
    },
    "limit": {
      "type": "integer",
      "minimum": 1,
      "maximum": 50
    },
    "page": {
      "type": "integer",
      "minimum": 1,
      "maximum": 500
    }
  },
  "additionalProperties": false
}
