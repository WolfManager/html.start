{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "magneto/domains/search/contracts/search-related-response.schema.json",
  "title": "SearchRelatedResponse",
  "type": "object",
  "required": ["ok", "query", "related", "generatedAt"],
  "properties": {
    "ok": { "type": "boolean" },
    "query": { "type": "string" },
    "related": {
      "type": "array",
      "items": { "type": "string" }
    },
    "generatedAt": { "type": "string", "format": "date-time" },
    "servedBy": { "type": "string", "enum": ["node", "django"] }
  },
  "additionalProperties": true
}
