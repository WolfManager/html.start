{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "magneto/domains/search/contracts/search-response.schema.json",
  "title": "SearchResponse",
  "type": "object",
  "required": [
    "query",
    "queryUsed",
    "appliedOperators",
    "queryCorrection",
    "querySuggestion",
    "suggestions",
    "relatedQueries",
    "total",
    "results",
    "servedBy"
  ],
  "properties": {
    "engine": {
      "type": "string"
    },
    "query": {
      "type": "string"
    },
    "queryUsed": {
      "type": "string"
    },
    "appliedOperators": {
      "type": "object",
      "required": [
        "site",
        "excludedSite",
        "filetype",
        "inurl",
        "intitle",
        "cleanedQuery"
      ],
      "properties": {
        "site": {
          "type": "array",
          "items": { "type": "string" }
        },
        "excludedSite": {
          "type": "array",
          "items": { "type": "string" }
        },
        "filetype": {
          "type": "array",
          "items": { "type": "string" }
        },
        "inurl": {
          "type": "array",
          "items": { "type": "string" }
        },
        "intitle": {
          "type": "array",
          "items": { "type": "string" }
        },
        "cleanedQuery": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "queryCorrection": {
      "type": ["object", "null"]
    },
    "querySuggestion": {
      "type": ["object", "null"]
    },
    "semanticFallback": {
      "type": ["object", "null"],
      "properties": {
        "suggestions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "reason": {
          "type": "string",
          "enum": [
            "sparse_results_semantic_fallback",
            "no_results_semantic_fallback"
          ]
        }
      }
    },
    "ltrVariant": {
      "type": ["string", "null"],
      "enum": ["control", "treatment", null],
      "description": "A/B test variant for learning-to-rank ranking algorithm"
    },
    "suggestions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "relatedQueries": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "total": {
      "type": "integer",
      "minimum": 0
    },
    "appliedFilters": {
      "type": "object"
    },
    "pagination": {
      "type": "object"
    },
    "facets": {
      "type": "object"
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "url"],
        "properties": {
          "title": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "language": {
            "type": "string"
          },
          "category": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "score": {
            "type": "number"
          }
        },
        "additionalProperties": true
      }
    },
    "servedBy": {
      "type": "string",
      "enum": ["node", "django"]
    }
  },
  "additionalProperties": true
}
