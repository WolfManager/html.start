{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "magneto/domains/admin/contracts/admin-click-signal-snapshot-reset-response.schema.json",
  "title": "AdminClickSignalSnapshotResetResponse",
  "type": "object",
  "required": ["ok", "generatedAt", "snapshot", "clickSignalTelemetry"],
  "properties": {
    "ok": {
      "type": "boolean"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "snapshot": {
      "type": "object",
      "required": ["generatedAt", "clickSignalConfig", "clickSignalTelemetry"],
      "properties": {
        "generatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "clickSignalConfig": {
          "type": "object",
          "required": [
            "windowDays",
            "decayHalfLifeDays",
            "decayMinWeight",
            "maxBoost",
            "ctrMaxBoost",
            "guardrailMinBaseScore",
            "guardrailMaxShare",
            "dedupSeconds"
          ],
          "properties": {
            "windowDays": { "type": "integer" },
            "decayHalfLifeDays": { "type": "integer" },
            "decayMinWeight": { "type": "number" },
            "maxBoost": { "type": "number" },
            "ctrMaxBoost": { "type": "number" },
            "guardrailMinBaseScore": { "type": "number" },
            "guardrailMaxShare": { "type": "number" },
            "dedupSeconds": { "type": "integer" }
          },
          "additionalProperties": true
        },
        "clickSignalTelemetry": {
          "type": "object",
          "required": [
            "searchesEvaluated",
            "docsEvaluated",
            "boostApplied",
            "suppressedMinBase",
            "suppressedNoSignal",
            "cappedByGuardrail",
            "totalBoost",
            "lastUpdatedAt",
            "lastRun"
          ],
          "properties": {
            "searchesEvaluated": { "type": "integer", "minimum": 0 },
            "docsEvaluated": { "type": "integer", "minimum": 0 },
            "boostApplied": { "type": "integer", "minimum": 0 },
            "suppressedMinBase": { "type": "integer", "minimum": 0 },
            "suppressedNoSignal": { "type": "integer", "minimum": 0 },
            "cappedByGuardrail": { "type": "integer", "minimum": 0 },
            "totalBoost": { "type": "number" },
            "lastUpdatedAt": { "type": "string" },
            "lastRun": { "type": ["object", "null"] }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "clickSignalTelemetry": {
      "type": "object",
      "required": [
        "searchesEvaluated",
        "docsEvaluated",
        "boostApplied",
        "suppressedMinBase",
        "suppressedNoSignal",
        "cappedByGuardrail",
        "totalBoost",
        "lastUpdatedAt",
        "lastRun"
      ],
      "properties": {
        "searchesEvaluated": { "type": "integer", "minimum": 0 },
        "docsEvaluated": { "type": "integer", "minimum": 0 },
        "boostApplied": { "type": "integer", "minimum": 0 },
        "suppressedMinBase": { "type": "integer", "minimum": 0 },
        "suppressedNoSignal": { "type": "integer", "minimum": 0 },
        "cappedByGuardrail": { "type": "integer", "minimum": 0 },
        "totalBoost": { "type": "number" },
        "lastUpdatedAt": { "type": "string" },
        "lastRun": { "type": ["object", "null"] }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
