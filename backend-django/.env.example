# Required in production: replace with a strong random secret (>=32 chars)
DJANGO_SECRET_KEY=change-this-django-secret
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:3100,http://localhost:3100

# Local MAGNETO migration ports (read by launcher and health-check)
MAGNETO_NODE_PORT=3000
MAGNETO_DJANGO_PORT=8000

# Database (choose one)
DATABASE_URL=
DB_ENGINE=sqlite3
DB_NAME=magneto
DB_USER=magneto
DB_PASSWORD=magneto
DB_HOST=127.0.0.1
DB_PORT=5432
DB_CONN_MAX_AGE=60

# Redis / cache / Celery
REDIS_URL=
DEFAULT_CACHE_TIMEOUT=300
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
CELERY_TASK_ALWAYS_EAGER=true
CELERY_TASK_TIME_LIMIT=120
CELERY_BROKER_CONNECTION_RETRY_ON_STARTUP=true
# On Windows use CELERY_WORKER_POOL=solo
CELERY_WORKER_POOL=solo

# Security hardening for non-debug deployments
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
SECURE_HSTS_SECONDS=31536000

ADMIN_USER=admin
# Required in production: replace with a strong password (>=12 chars)
ADMIN_PASSWORD=change-this-password
# Required in production: replace with a strong random secret (>=32 chars)
JWT_SECRET=change-this-secret
LOGIN_WINDOW_MINUTES=15
LOGIN_RATE_LIMIT_COUNT=20
LOCKOUT_THRESHOLD=5
LOCKOUT_MINUTES=15
ADMIN_WINDOW_SECONDS=60
ADMIN_RATE_LIMIT_COUNT=120

# Optional: align names with the existing Node app env where useful
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MODEL_CANDIDATES=gpt-4o-mini,gpt-4.1-mini,gpt-5-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MODEL_CANDIDATES=claude-sonnet-4-6,claude-opus-4-6,claude-haiku-4-5-20251001
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MODEL_CANDIDATES=gemini-1.5-flash,gemini-1.5-pro,gemini-2.0-flash,gemini-2.0-flash-lite

AI_PRIMARY_PROVIDER=openai
AI_FALLBACK_PROVIDER=anthropic
AI_PROVIDER_ORDER=openai,anthropic,gemini
AI_ROUTING_MODE=smart
ASSISTANT_COMPLEX_QUERY_WORDS=35
ASSISTANT_COMPLEX_QUERY_CHARS=220

ASSISTANT_MAX_CHARS=4000
ASSISTANT_HTTP_TIMEOUT_SECONDS=20
ASSISTANT_MODEL_DISCOVERY_TTL_SECONDS=21600
ASSISTANT_WINDOW_SECONDS=60
ASSISTANT_RATE_LIMIT_COUNT=240
ASSISTANT_CACHE_TTL_SECONDS=900
ASSISTANT_CACHE_MAX_ENTRIES=500
ASSISTANT_MEMORY_MAX_ITEMS=2000
